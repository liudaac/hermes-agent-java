{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync-assets": "node scripts/sync-assets.mjs",
    "predev": "npm run sync-assets",
    "prebuild": "npm run sync-assets",
    "dev": "concurrently -n hub,portal,ops,noc -c green,magenta,blue,yellow \"vite\" \"npm:dev:portal\" \"npm:dev:ops\" \"npm:dev:noc\"",
    "dev:hub": "vite",
    "dev:portal": "npm --prefix portal run dev",
    "dev:ops": "npm --prefix ops run dev",
    "dev:noc": "npm --prefix noc run dev",
    "build": "npm run build:all",
    "build:hub": "tsc -b && vite build",
    "build:portal": "npm --prefix portal run build",
    "build:ops": "npm --prefix ops run build",
    "build:noc": "npm --prefix noc run build",
    "build:all": "npm run build:hub && npm run build:portal && npm run build:ops && npm run build:noc",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@nous-research/ui": "^0.3.0",
    "@observablehq/plot": "^0.6.17",
    "@react-three/fiber": "^9.6.0",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "leva": "^0.10.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "three": "^0.180.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
